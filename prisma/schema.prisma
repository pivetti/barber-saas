// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum BarberRole {
  OWNER
  ADMIN
  BARBER
}

model User {
  id        String   @id @default(uuid())
  name      String   @unique
  phone     String
  password  String
  sessionVersion Int @default(0)
  bookings  Booking[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String    @id @default(uuid())
  name        String
  description String
  imageUrl    String
  price       Decimal   @db.Decimal(10, 2)
  bookings    Booking[]
}

model Barber {
  id              String              @id @default(uuid())
  name            String
  email           String?             @unique
  phone           String?             @unique
  password        String?
  sessionVersion  Int                 @default(0)
  imageUrl        String
  role            BarberRole          @default(BARBER)
  isActive        Boolean             @default(true)
  bookings        Booking[]
  availabilities  BarberAvailability[]
  blockedDays     BarberBlockedDay[]
  blockedSlots    BarberBlockedSlot[]
  workingHours    WorkingHour[]
  blockedTimes    BlockedTime[]
  scheduleSetting ScheduleSettings?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Booking {
  id                    String    @id @default(uuid())
  userId                String?
  user                  User?     @relation(fields: [userId], references: [id])
  customerName          String
  customerPhone         String
  cancellationToken     String    @unique
  cancellationRequested Boolean   @default(false)
  cancellationRequestedAt DateTime?
  status                String    @default("SCHEDULED") // SCHEDULED, DONE, CANCELED
  serviceId             String
  barberId              String?
  barber                Barber?   @relation(fields: [barberId], references: [id])
  date                  DateTime
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  service               Service   @relation(fields: [serviceId], references: [id])
}

model BarberAvailability {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, dayOfWeek, time])
  @@index([barberId, dayOfWeek])
}

model BarberBlockedDay {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, date])
  @@index([barberId, date])
}

model BarberBlockedSlot {
  id        String   @id @default(uuid())
  barberId  String
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barberId, date])
  @@index([barberId, date])
}

model WorkingHour {
  id        String   @id @default(uuid())
  barberId  String   @map("barber_id")
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([barberId, dayOfWeek, startTime, endTime])
  @@index([barberId, dayOfWeek])
  @@map("working_hours")
}

model BlockedTime {
  id        String   @id @default(uuid())
  barberId  String   @map("barber_id")
  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  date      DateTime
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([barberId, date])
  @@map("blocked_times")
}

model ScheduleSettings {
  id                  String   @id @default(uuid())
  barberId            String   @unique @map("barber_id")
  barber              Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  slotIntervalMinutes Int      @default(30) @map("slot_interval_minutes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("schedule_settings")
}

model AdminLoginAttempt {
  id              String   @id @default(uuid())
  email           String
  ipAddress       String
  failedAttempts  Int      @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  lastAttemptAt   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([email, ipAddress])
  @@index([blockedUntil])
}
